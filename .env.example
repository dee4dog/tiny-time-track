# Tiny Time Track - bootstrap configuration
# Copy this file to ".env" and edit. All keys are optional; sensible
# defaults are used if absent. These are the settings needed *before*
# the database exists. Manager-editable business settings (overhead
# multiplier, SMTP, reminder times) live in the database, not here.

# Path to the single-file SQLite database. On the office server, point
# this at a real data drive, e.g. D:\Tiny Time Track\timetrack.db
TIMETRACK_DB_PATH=timetrack.db

# Secret used to sign session cookies. CHANGE THIS to a long random string.
# Generate one with:  python -c "import secrets; print(secrets.token_hex(32))"
TIMETRACK_SECRET_KEY=dev-insecure-change-me-please

# Network bind for the web server.
TIMETRACK_HOST=0.0.0.0
TIMETRACK_PORT=8000

# IANA timezone (used by the reminder scheduler and week calculations).
TIMETRACK_TIMEZONE=Africa/Johannesburg

# Folder for nightly SQLite backups (Phase 6).
TIMETRACK_BACKUP_PATH=backups
